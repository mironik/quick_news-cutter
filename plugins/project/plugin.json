{
  "plugin_id": "project",
  "tab_id": "project",
  "label": "Project",
  "priority": -1000,
  "position": "first",
  "entry_js": "/plugins/project/static/qnc-project.js",
  "entry_css": "/plugins/project/static/qnc-project.css",
  "asset_version": 55,
  "panel_id": "panel-project",
  "keep_alive": true,
  "api_namespace": "/api/projects",
  "storage": "project",
  "enabled": true,
  "system": true,
  "removable": false,
  "description": "Project tab — shell-plugin-tab + project-list + project-template-settings.",
  "panel_html": "/app/components/project-tab-layout/component.html",
  "uses_components": [
    "shell-plugin-tab",
    "project-tab-layout",
    "workspace-split",
    "project-list",
    "folder-picker",
    "project-template-settings"
  ],
  "sdk_version": 1,
  "state": {
    "snapshots": [
      {
        "key": "project.index",
        "method": "GET",
        "path": "/api/projects"
      },
      {
        "key": "project.templates",
        "method": "GET",
        "path": "/api/project-templates"
      },
      {
        "key": "project.modules",
        "method": "GET",
        "path": "/api/modules",
        "pick": "modules"
      },
      {
        "key": "project.ui",
        "method": "GET",
        "path": "/api/projects/ui-state",
        "pick": "ui_state"
      }
    ]
  },
  "backend": {
    "implementation": "rust",
    "host_module": "qnc-host/src/project",
    "store": {
      "scope": "project",
      "path": "project"
    },
    "actions": [
      {
        "action": "project.ui.patch",
        "method": "POST",
        "path": "/api/projects/ui-state",
        "writes": ["project.ui"]
      },
      {
        "action": "project.create",
        "method": "POST",
        "path": "/api/projects/from-template",
        "writes": ["project.index", "project.ui"]
      },
      {
        "action": "project.open",
        "method": "POST",
        "path": "/api/projects/open",
        "writes": ["project.index"]
      },
      {
        "action": "project.delete",
        "method": "POST",
        "path": "/api/projects/delete",
        "writes": ["project.index", "project.ui"]
      },
      {
        "action": "template.save-custom",
        "method": "POST",
        "path": "/api/project-templates",
        "writes": ["project.templates", "project.ui"]
      }
    ],
    "jobs": []
  }
}
