{
  "plugin_id": "story",
  "tab_id": "storyboard",
  "label": "Story",
  "priority": 200,
  "position": "normal",
  "entry_js": "/plugins/story/static/qnc-story.js",
  "entry_css": "/plugins/story/static/qnc-story.css",
  "asset_version": 1,
  "panel_id": "panel-storyboard",
  "api_namespace": "/api/story",
  "storage": "story",
  "enabled": true,
  "system": true,
  "removable": false,
  "description": "Story tab — DB-backed montage skeleton (Plugin SDK v1).",
  "panel_html": "/app/components/story-tab-layout/component.html",
  "uses_components": [
    "story-tab-layout"
  ],
  "sdk_version": 1,
  "state": {
    "snapshots": [
      {
        "key": "story.state",
        "method": "GET",
        "path": "/api/story/state",
        "query": ["project_id"]
      }
    ],
    "invalidates_on": ["project:changed"]
  },
  "consumes": {
    "shell_events": ["project:changed"]
  },
  "backend": {
    "implementation": "rust",
    "host_module": "qnc-host/src/story",
    "store": {
      "scope": "project",
      "persistence": "project_db"
    },
    "actions": [],
    "jobs": []
  }
}
